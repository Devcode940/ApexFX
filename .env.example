# ============================================================================
# ApexFX Terminal - Environment Configuration
# ============================================================================
# ALL variables marked as REQUIRED must be set for the application to run.

# Node environment (development/production)
NODE_ENV="development"

# Server port
PORT=3000

# ============================================================================
# REQUIRED API KEYS
# ============================================================================

# Twelve Data API Key (REQUIRED - live prices and historical data)
# Get at: https://twelvedata.com/register
TWELVEDATA_API_KEY=""

# Gemini AI API Key (optional - AI chat functionality; without it, chat degrades gracefully)
# Get at: https://aistudio.google.com/apikey
GEMINI_API_KEY=""

# ============================================================================
# OPTIONAL API KEYS
# ============================================================================

# Finnhub API Key (optional - market news feed)
# Get at: https://finnhub.io/register
FINNHUB_API_KEY=""

# ForexRate API Key (optional - fallback forex rates)
FOREXRATE_API_KEY=""

# ============================================================================
# SERVER CONFIGURATION
# ============================================================================

# CORS Origin (default: * for development)
CORS_ORIGIN="*"

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ============================================================================
# OPTIONAL SERVICES
# ============================================================================

# Firebase Configuration (optional)
VITE_FIREBASE_API_KEY=""
VITE_FIREBASE_AUTH_DOMAIN=""
VITE_FIREBASE_PROJECT_ID=""
VITE_FIREBASE_STORAGE_BUCKET=""
VITE_FIREBASE_MESSAGING_SENDER_ID=""
VITE_FIREBASE_APP_ID=""

# Supabase Configuration (optional)
VITE_SUPABASE_URL=""
VITE_SUPABASE_ANON_KEY=""
